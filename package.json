{
  "name": "r6-suspect-tracker",
  "private": true,
  "description": "R6 suspect checker: static UI in public/ + Vercel serverless API + optional Next + PostgreSQL",
  "scripts": {
    "dev": "node scripts/local-dev.cjs",
    "check": "node scripts/check.cjs",
    "build": "next build",
    "next:dev": "next dev -p 3001",
    "next:build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:validate": "dotenv -e .env.example -- prisma validate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:pull": "dotenv -e .env.local -- prisma db pull",
    "db:seed": "dotenv -e .env.local -- node prisma/seed.cjs",
    "auth:hash": "node scripts/hash-password.cjs",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "vercel-build": "prisma generate && next build",
    "prepare": "husky"
  },
  "dependencies": {
    "@netlify/plugin-nextjs": "^5.13.2",
    "@prisma/client": "^6.19.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^8.0.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "prisma": "^6.19.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
