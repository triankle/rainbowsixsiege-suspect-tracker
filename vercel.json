{
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "framework": "nextjs",
  "rewrites": [
    { "source": "/api/v1/submissions", "destination": "/api/submissions" },
    { "source": "/api/v1/entries", "destination": "/api/entries" },
    { "source": "/api/v1/stats", "destination": "/api/stats" },
    { "source": "/api/v1/export.csv", "destination": "/api/export.csv" },
    { "source": "/api/v1/auth/login", "destination": "/api/auth/login" },
    { "source": "/api/v1/auth/me", "destination": "/api/auth/me" }
  ]
}
