# Copy to .env.local for `vercel dev` (never commit secrets)

# PostgreSQL connection string (Neon, Supabase, Vercel Postgres, local Postgres, etc.)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Optional: if set, POST /api/submissions requires header x-save-key with the same value
# SAVE_API_KEY=your-long-random-string

# Optional locally, required in production by api/entries.js:
# GET /api/entries requires header x-read-key with the same value
# READ_API_KEY=your-other-long-random-string

# Optional admin JWT demo auth:
# Generate AUTH_PASSWORD_HASH with: npm run auth:hash -- "Demo1234!Demo"
# AUTH_USERNAME=admin
# AUTH_PASSWORD_HASH=scrypt$example-salt$example-derived-key
# AUTH_JWT_SECRET=replace-with-at-least-32-random-characters
